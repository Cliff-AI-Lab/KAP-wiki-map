# ============================================
# 知识图鉴 V15 · 睿动 (iRuidong) 平台接入模板
# ============================================
# 用法：
#   1. 复制本文件为 .env.ruidong  (cp .env.ruidong.example .env.ruidong)
#   2. 填入睿动 API Key（见下方 RUIDONG_API_KEY）
#   3. 切换到本配置：cp .env.ruidong .env  （或 PowerShell 下 Copy-Item）
#   4. 运行验证：python scripts/test_ruidong.py
#   5. 启动后端：python -X utf8 -m uvicorn api.main:app --host 0.0.0.0 --port 8000
# ============================================

# === 睿动 LLM 网关 (OpenAI 兼容) ===
OPENAI_API_KEY=<在此填入睿动 API Key>
OPENAI_BASE_URL=https://iruidong.com/v1

# 默认模型 — 不硬编码，运行时由 scripts/test_ruidong.py 遍历 /v1/models 产出推荐
# 这里先填一个占位值，跑通后改为实际可用模型名
LLM_PROVIDER=openai
LLM_MODEL=<跑 test_ruidong.py 后选一个聊天模型填入>

# === Embedding (暂保持 mock，待睿动 embedding 模型确认后启用) ===
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock
EMBEDDING_DIM=1536

# === 数据库 (延用本地 V14 配置) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookworm
POSTGRES_USER=bookworm
POSTGRES_PASSWORD=<请设置强密码>

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<请设置>
MINIO_SECRET_KEY=<请设置>
MINIO_BUCKET=bookworm-archive

# === 其他配置保持默认 ===
SCORE_ALPHA=0.40
SCORE_BETA=0.35
SCORE_GAMMA=0.25
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60
CHUNK_STRATEGY=fixed
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RERANKER_PROVIDER=mock
AUTH_REQUIRED=false
API_PORT=8000
API_HOST=0.0.0.0
