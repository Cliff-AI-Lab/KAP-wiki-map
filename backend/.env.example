# ============================================
# KAP 知识智能体平台 · 后端环境变量主模板
# ============================================
# 用法：
#   开发环境  → cp .env.dev.example .env  （含 mock fallback、本地基建）
#   沙箱环境  → cp .env.sandbox.example .env  （走睿动沙箱、禁 mock）
#   生产环境  → cp .env.prod.example .env  （Key 走后端代理、严格审计）
#
# 本文件是字段总览参考，不直接使用。
# 任何字段变更必须同步到三个 *.example 文件。
# ============================================

# === 环境标识（必填，影响 mock fallback / 审计严格度）===
KAP_ENV=dev                           # dev / sandbox / prod

# === LLM 网关（睿动 iRuidong，OpenAI 兼容）===
# 不硬编码模型名 — 模型由 /v1/models 动态拉取，客户端过滤聊天模型
OPENAI_API_KEY=                       # 睿动 API Key（生产环境走后端代理）
OPENAI_BASE_URL=https://iruidong.com/v1
SANDBOX_API_BASE=                     # 沙箱环境覆盖（如 https://sandbox.iruidong.internal/v1）
LLM_PROVIDER=openai
LLM_MODEL=                            # 跑 scripts/test_ruidong.py 后选一个填入

# === Embedding（私有化必须本地化，禁止生产环境 mock）===
EMBEDDING_PROVIDER=bge                # bge / bce / openai / mock（仅 dev 允许 mock）
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
KAP_ALLOW_MOCK_EMBEDDING=false        # M0-tech-debt 坑 6：sandbox/prod 必须 false

# === Reranker ===
RERANKER_PROVIDER=bge                 # bge / cohere / mock
RERANKER_CANDIDATE_MULTIPLIER=3

# === PostgreSQL（业务/知识元数据）===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kap
POSTGRES_USER=kap
POSTGRES_PASSWORD=

# === Neo4j（持久化知识图谱，决策书 §10.4 必须）===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# === Milvus（双向量库）===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MinIO / 对象存储 ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=kap-archive

# === HTTP 客户端 ===
HTTPX_VERIFY_SSL=true                 # M0-tech-debt 坑 D：sandbox/prod 必须 true
HTTPX_TIMEOUT=60

# === 评分权重（HybridScorer α/β/γ/δ）===
SCORE_ALPHA=0.35                      # 向量
SCORE_BETA=0.25                       # 图谱
SCORE_GAMMA=0.15                      # 目录
SCORE_DELTA=0.25                      # BM25

# === 决策阈值（M0-tech-debt 坑 3：未来按行业模板覆盖）===
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60

# === Agent 参数 ===
LIBRARIAN_PREVIEW_CHARS=2000
JUDGE_CONTENT_CHARS=3000

# === 切块策略 ===
CHUNK_STRATEGY=fixed                  # fixed / sop / faq / technical（M1 按文档类型分流）
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# === 认证（M0 仅骨架，M1 完整对接 ISS-Auth）===
AUTH_REQUIRED=false                   # sandbox/prod 必须 true
JWT_SECRET=                           # 生产环境必填，长度 ≥ 32
JWT_TTL_MINUTES=720
JWT_REFRESH_MINUTES=120

# === 服务 ===
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === 行业模板（M1 上线，M0 占位）===
KAP_INDUSTRY_TEMPLATE=energy          # energy / manufacturing-discrete / manufacturing-process / ...
KAP_TEMPLATES_DIR=templates

# === 连接器（M1 接入真实，M0 mock）===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_MOCK_MODE=true
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_MOCK_MODE=true
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_MOCK_MODE=true
