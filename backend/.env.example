# === 大模型 API ===
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-xxx

# 默认使用的大模型（judge/refiner）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# === 飞书连接器 ===
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
# 设为 true 使用模拟数据（无需真实飞书凭证）
FEISHU_MOCK_MODE=true

# === 数据库 ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookworm
POSTGRES_USER=bookworm
POSTGRES_PASSWORD=<请设置强密码>

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<请设置强密码>

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<请设置访问密钥>
MINIO_SECRET_KEY=<请设置密钥>
MINIO_BUCKET=bookworm-archive

# === Embedding 模型 ===
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# === 评分权重 ===
SCORE_ALPHA=0.40
SCORE_BETA=0.35
SCORE_GAMMA=0.25

# === 决策阈值 ===
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60

# === Agent 参数 ===
LIBRARIAN_PREVIEW_CHARS=2000
JUDGE_CONTENT_CHARS=3000

# === 钉钉连接器 ===
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_MOCK_MODE=true

# === 企业微信连接器 ===
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_MOCK_MODE=true

# === 切片策略 ===
CHUNK_STRATEGY=fixed
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# === Reranker ===
RERANKER_PROVIDER=mock
RERANKER_CANDIDATE_MULTIPLIER=3

# === 关键词评分权重 (BM25 delta) ===
SCORE_DELTA=0.25

# === 认证 ===
AUTH_REQUIRED=false

# === 服务端口 ===
API_PORT=8000
API_HOST=0.0.0.0
