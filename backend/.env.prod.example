# ============================================
# KAP 后端 · PROD 生产环境配置（敏感字段全部走外部密钥管理）
# ============================================
# 复制为 .env：cp .env.prod.example .env  之后**禁止**将填好的 .env 入库
# 设计目的：客户私有化生产部署
#   - API Key 通过后端代理 / KMS 注入，禁止前端持有
#   - 真嵌入 + 真 LLM，全链路审计
#   - 严格 SSL 校验、严格 RBAC
# ============================================
#
# **重要**：本文件示例中所有 secret 都标记为 "<由 KMS 注入>"。
# 实际部署时通过以下任一方式注入：
#   - K8s Secret + ConfigMap
#   - HashiCorp Vault Agent Sidecar
#   - 客户自有 KMS（阿里云 KMS / 华为云 KMS / 腾讯云 KMS）
#   - 启动脚本从密钥服务拉取后写入 /run/secrets/
# **禁止**：
#   - 把生产 Key 写在源码或 docker image
#   - 把 .env 入 git
#   - 在 dev/sandbox 复用生产 Key
# ============================================

KAP_ENV=prod

# === LLM 网关 ===
OPENAI_API_KEY=<由 KMS 注入>
OPENAI_BASE_URL=https://iruidong.com/v1   # 或客户内网网关
LLM_PROVIDER=openai
LLM_MODEL=                            # 客户上线前选定，禁硬编码

# === Embedding ===
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
KAP_ALLOW_MOCK_EMBEDDING=false        # 生产环境启动时强制校验为 false

# === Reranker ===
RERANKER_PROVIDER=bge
RERANKER_CANDIDATE_MULTIPLIER=3

# === PostgreSQL ===
POSTGRES_HOST=<由 KMS 注入>
POSTGRES_PORT=5432
POSTGRES_DB=kap_prod
POSTGRES_USER=<由 KMS 注入>
POSTGRES_PASSWORD=<由 KMS 注入>

# === Neo4j ===
NEO4J_URI=<由 KMS 注入>
NEO4J_USER=<由 KMS 注入>
NEO4J_PASSWORD=<由 KMS 注入>

# === Milvus ===
MILVUS_HOST=<由 KMS 注入>
MILVUS_PORT=19530

# === Redis ===
REDIS_URL=<由 KMS 注入>                # 含密码：redis://:<pwd>@<host>:6379/0

# === 对象存储（生产推荐 OBS / OSS / S3，不要用 MinIO）===
MINIO_ENDPOINT=<由 KMS 注入>           # 或 obs.<region>.myhuaweicloud.com
MINIO_ACCESS_KEY=<由 KMS 注入>
MINIO_SECRET_KEY=<由 KMS 注入>
MINIO_BUCKET=kap-prod-archive

# === HTTP（生产严格校验 SSL）===
HTTPX_VERIFY_SSL=true                 # 启动时强制校验为 true
HTTPX_TIMEOUT=60

# === 评分权重（生产可热更新，由行业模板覆盖）===
SCORE_ALPHA=0.35
SCORE_BETA=0.25
SCORE_GAMMA=0.15
SCORE_DELTA=0.25

# === 决策阈值（生产由行业模板包覆盖，本文件仅作 fallback）===
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60

LIBRARIAN_PREVIEW_CHARS=2000
JUDGE_CONTENT_CHARS=3000

# === 切块（生产按文档类型分流，M1 上线后由模板包决定）===
CHUNK_STRATEGY=fixed
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# === 认证（生产强制 ISS-Auth，含 JWT + Redis 会话 + IP 黑名单 + 重试锁定）===
AUTH_REQUIRED=true                    # 启动时强制校验为 true
JWT_SECRET=<由 KMS 注入>               # ≥ 64 字符
JWT_TTL_MINUTES=720
JWT_REFRESH_MINUTES=120

# === 服务 ===
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=                         # 生产仅允许客户实际前端域名，禁 *

# === 行业模板（按客户实际签约行业固化）===
KAP_INDUSTRY_TEMPLATE=
KAP_TEMPLATES_DIR=/data/kap/templates  # 生产建议放挂载卷

# === 连接器（按客户实际启用）===
FEISHU_APP_ID=
FEISHU_APP_SECRET=<由 KMS 注入>
FEISHU_VERIFICATION_TOKEN=<由 KMS 注入>
FEISHU_MOCK_MODE=false
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=<由 KMS 注入>
DINGTALK_MOCK_MODE=false
WECOM_CORP_ID=
WECOM_CORP_SECRET=<由 KMS 注入>
WECOM_MOCK_MODE=false
