# ============================================
# KAP 后端 · SANDBOX 沙箱环境配置
# ============================================
# 复制为 .env：cp .env.sandbox.example .env
# 设计目的：客户演示 / PoC 联调环境
#   - 走睿动沙箱 URL（通过 SANDBOX_API_BASE 覆盖）
#   - 真嵌入 + 真 LLM，禁 mock
#   - 接近生产配置但密码使用沙箱占位值
# ============================================

KAP_ENV=sandbox

# === LLM 网关（睿动沙箱）===
OPENAI_API_KEY=                       # 沙箱 Key（睿动控制台→沙箱）
OPENAI_BASE_URL=https://iruidong.com/v1
SANDBOX_API_BASE=                     # 必填：客户内网沙箱 URL（如 https://sandbox.iruidong.<customer>.internal/v1）
LLM_PROVIDER=openai
LLM_MODEL=                            # 由客户测试后选定填入（避免硬编码）

# === Embedding（沙箱必须真嵌入）===
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
KAP_ALLOW_MOCK_EMBEDDING=false        # 严格禁止 mock（M0-tech-debt 坑 6）

# === Reranker ===
RERANKER_PROVIDER=bge
RERANKER_CANDIDATE_MULTIPLIER=3

# === 数据库（沙箱独立实例，不共用 dev）===
POSTGRES_HOST=                        # 必填：沙箱 PG 实例
POSTGRES_PORT=5432
POSTGRES_DB=kap_sandbox
POSTGRES_USER=kap_sandbox
POSTGRES_PASSWORD=                    # 必填：从沙箱密钥管理获取

# === Neo4j ===
NEO4J_URI=                            # 必填：bolt://<sandbox-neo4j>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# === Milvus ===
MILVUS_HOST=                          # 必填
MILVUS_PORT=19530

# === Redis ===
REDIS_URL=                            # 必填：redis://<sandbox-redis>:6379/0

# === MinIO / 对象存储 ===
MINIO_ENDPOINT=                       # 必填
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=kap-sandbox-archive

# === HTTP ===
HTTPX_VERIFY_SSL=true                 # 沙箱必须 true
HTTPX_TIMEOUT=60

# === 评分权重 ===
SCORE_ALPHA=0.35
SCORE_BETA=0.25
SCORE_GAMMA=0.15
SCORE_DELTA=0.25

# === 决策阈值（沙箱可调，M1 后由行业模板覆盖）===
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60

LIBRARIAN_PREVIEW_CHARS=2000
JUDGE_CONTENT_CHARS=3000

# === 切块 ===
CHUNK_STRATEGY=fixed
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# === 认证（沙箱必须开启，对齐生产）===
AUTH_REQUIRED=true
JWT_SECRET=                           # 必填：≥32 字符强随机
JWT_TTL_MINUTES=720
JWT_REFRESH_MINUTES=120

# === 服务 ===
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=                         # 必填：客户沙箱前端域名

# === 行业模板（按客户实际行业切换）===
KAP_INDUSTRY_TEMPLATE=                # energy / manufacturing-discrete / ...
KAP_TEMPLATES_DIR=templates

# === 连接器（沙箱可启用真飞书/钉钉沙箱凭证）===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_MOCK_MODE=false
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_MOCK_MODE=false
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_MOCK_MODE=false
