# ============================================
# KAP 后端 · DEV 开发环境配置
# ============================================
# 复制为 .env：cp .env.dev.example .env
# 设计目的：本地全栈开发，docker-compose 起基建，允许 mock fallback
# ============================================

KAP_ENV=dev

# === LLM 网关（睿动开发 Key）===
OPENAI_API_KEY=                       # 填本地开发用睿动 Key
OPENAI_BASE_URL=https://iruidong.com/v1
LLM_PROVIDER=openai
LLM_MODEL=glm-5.1                     # 推荐：性价比平衡，可换 claude-sonnet-4-6

# === Embedding（dev 允许 mock 加速）===
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock
EMBEDDING_DIM=1024
KAP_ALLOW_MOCK_EMBEDDING=true

# === Reranker（dev mock）===
RERANKER_PROVIDER=mock

# === 本地基建（指向 infra/docker-compose.dev.yml）===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kap
POSTGRES_USER=kap
POSTGRES_PASSWORD=kap_dev_pwd

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kap_dev_pwd

MILVUS_HOST=localhost
MILVUS_PORT=19530

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kap-archive

# === HTTP（dev 可能需要跳过 SSL 校验访问内网）===
HTTPX_VERIFY_SSL=false                # 仅 dev 允许 false
HTTPX_TIMEOUT=60

# === 评分权重 ===
SCORE_ALPHA=0.35
SCORE_BETA=0.25
SCORE_GAMMA=0.15
SCORE_DELTA=0.25

# === 决策阈值 ===
KPI_DISCARD_THRESHOLD=0.20
KPI_ARCHIVE_THRESHOLD=0.45
REVIEW_CONFIDENCE_THRESHOLD=0.60

LIBRARIAN_PREVIEW_CHARS=2000
JUDGE_CONTENT_CHARS=3000

# === 切块 ===
CHUNK_STRATEGY=fixed
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# === 认证（dev 关闭，便于 curl 调试）===
AUTH_REQUIRED=false
JWT_SECRET=dev_jwt_secret_at_least_32_chars_for_local_only
JWT_TTL_MINUTES=720
JWT_REFRESH_MINUTES=120

# === 服务 ===
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === 行业模板（dev 默认能源，便于复用 V15 53 域 demo 数据）===
KAP_INDUSTRY_TEMPLATE=energy
KAP_TEMPLATES_DIR=templates

# === 连接器（dev 全 mock）===
FEISHU_MOCK_MODE=true
DINGTALK_MOCK_MODE=true
WECOM_MOCK_MODE=true
